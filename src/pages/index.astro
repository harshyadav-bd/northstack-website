---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';

const jsonLdData = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'NorthStack Labs Inc.',
  url: 'https://northstacklabs.ca',
  description: 'A small software studio in Ontario, Canada.',
  founder: { '@type': 'Person', name: 'Harsh Yadav' },
  address: { '@type': 'PostalAddress', addressRegion: 'Ontario', addressCountry: 'CA' },
};
---

<BaseLayout
  title="NorthStack Labs - Software Studio in Ontario, Canada"
  description="Software studio in Ontario, Canada. We build apps, tools, and automations for businesses and everyday users."
  navVariant="homepage"
  footerVariant="homepage"
>
  <Fragment slot="head">
    <JsonLd data={jsonLdData} />
  </Fragment>

  <!-- HERO -->
  <header class="hero">
    <div class="hero-badge">// &#127464;&#127462; Built in Ontario, Canada</div>
    <h1>Thoughtful software,<br>made by a <span class="green">small team<svg aria-hidden="true" viewBox="0 0 200 12" preserveAspectRatio="none"><path d="M2 8 Q50 2 100 7 Q150 12 198 4"/></svg></span>.</h1>
    <p class="hero-sub">
      I'm Harsh, a developer who works across the full stack, from clean frontends to scalable backends. NorthStack Labs is where I ship the things I care about.
    </p>
    <div class="hero-cta">
      <a href="#gopulse" class="btn btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
        See What I'm Building
      </a>
      <a href="#contact" class="btn btn-secondary">Say Hello</a>
    </div>
  </header>

  <!-- ABOUT -->
  <section class="about" id="about">
    <div class="section-inner">
      <div class="section-label">About</div>
      <h2 class="section-title">Less noise.<br>Better software.</h2>
      <div class="about-grid fade-up">
        <div class="about-text">
          <p>
            NorthStack started because I wanted to build things on my own terms. Software I'd actually use, built the way I think software should be built.
          </p>
          <p>
            GOPulse was the first one. I ride GO Transit almost every day, and the experience was frustrating enough to do something about it.
          </p>
          <p>
            That's the approach. I care about how things work, from interface to infrastructure, and that standard applies to everything I build.
          </p>
        </div>
        <div class="about-values">
          <div class="value-card">
            <span class="value-num">01</span>
            <h4>Build for Scale</h4>
            <p>No shortcuts. Everything is built for the long term, designed to scale, not just to work today.</p>
          </div>
          <div class="value-card">
            <span class="value-num">02</span>
            <h4>Design Is Not Optional</h4>
            <p>Clear structure. Thoughtful interfaces. Details matter. Software should feel as good as it works.</p>
          </div>
          <div class="value-card">
            <span class="value-num">03</span>
            <h4>Solve It, Don't Sell It</h4>
            <p>No growth hacks. No feature gates. No dark patterns. Build something useful, and let that do the talking.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GOPULSE PRODUCT -->
  <section class="product" id="gopulse">
    <div class="section-inner">
      <div class="section-label">Product</div>
      <h2 class="section-title">Meet GOPulse</h2>
      <p class="section-desc">
        For anyone who rides GO regularly. No clutter, no menus to dig through. Just your trains, your station, and the stuff you actually care about.
      </p>

      <div class="product-showcase fade-up">
        <div class="product-info">
          <div class="product-logo">
            <div class="product-logo-icon">
              <img src="/images/app-icon - go pulse.png" alt="GOPulse icon" style="width: 100%; height: 100%; border-radius: 12px; object-fit: cover;">
            </div>
            <span>GOPulse</span>
          </div>

          <div class="product-tagline">
            Your train.<br>Your station.<br>Your alerts.
          </div>

          <p class="product-desc">
            Open the app and your next departure is right there. Save your regular journeys and GOPulse handles the rest. It finds your closest station and shows you what's leaving next. Built in Ontario by people who actually ride GO.
          </p>

          <div class="store-badges">
            <span class="store-badge" style="cursor: default;">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div class="store-badge-text">
                <span class="store-badge-small">Available soon on</span>
                <span class="store-badge-big">App Store & Google Play</span>
              </div>
            </span>
          </div>
        </div>

        <div class="screenshot-carousel" id="carousel">
          <div class="carousel-phone">
          <div class="carousel-viewport">
            <div class="carousel-track" id="carouselTrack">
              <img src="/images/IMG_2355.PNG" alt="GOPulse - Screenshot 1">
              <img src="/images/IMG_2356.PNG" alt="GOPulse - Screenshot 2">
              <img src="/images/IMG_2397.png" alt="GOPulse - Screenshot 3">
              <img src="/images/IMG_2393.png" alt="GOPulse - Screenshot 4">
              <img src="/images/IMG_2394.png" alt="GOPulse - Screenshot 5">
              <img src="/images/IMG_2396.png" alt="GOPulse - Screenshot 6">
            </div>
          </div>
          </div>
          <div class="carousel-controls">
            <button class="carousel-btn" id="carouselPrev" aria-label="Previous screenshot">&lsaquo;</button>
            <div class="carousel-dots" id="carouselDots">
              <button class="carousel-dot active" aria-label="Screenshot 1"></button>
              <button class="carousel-dot" aria-label="Screenshot 2"></button>
              <button class="carousel-dot" aria-label="Screenshot 3"></button>
              <button class="carousel-dot" aria-label="Screenshot 4"></button>
              <button class="carousel-dot" aria-label="Screenshot 5"></button>
              <button class="carousel-dot" aria-label="Screenshot 6"></button>
            </div>
            <button class="carousel-btn" id="carouselNext" aria-label="Next screenshot">&rsaquo;</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="section-inner">
      <div class="section-label">GOPulse Features</div>
      <h2 class="section-title">Here's how<br>it works.</h2>
      <p class="section-desc">
        Everything you need for your commute. Nothing you don't.
      </p>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00853E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Live Train Tracking</h3>
          <p>See your train on the map. Not a countdown, not an estimate. The actual train, moving in real time across all GO lines.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00853E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Smart Dashboard</h3>
          <p>Add the journeys you take regularly and GOPulse figures out where you are, finds your closest station, and shows what's leaving next.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00853E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
          </div>
          <h3>Smart Reminders</h3>
          <p>Pick your arrival time, pick your days, add a buffer for getting to the station. You'll get a notification when it's time to head out.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00853E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3>Real-Time Alerts</h3>
          <p>Disruptions, delays, and modified trips show up right on your home screen. No more finding out once you get to the station.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00853E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8l-4 4-4-4"/><path d="M8 16l4-4 4 4"/></svg>
          </div>
          <h3>Trip Planner</h3>
          <p>Going somewhere you don't usually go? Search any route and get schedules, options, and PRESTO fares all in one place.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00853E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>Station Details</h3>
          <p>Parking availability, facilities, accessibility info, and platform details for every GO station in the network.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">
    <div class="section-inner">
      <div class="section-label">Contact</div>
      <h2 class="section-title">Get in touch.</h2>
      <p class="section-desc">
        Got a question or feedback? Send us an email.
      </p>

      <div class="contact-grid fade-up">
          <div class="contact-item">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact-detail">
              <a href="mailto:hello@northstacklabs.ca">hello@northstacklabs.ca</a>
              <small>We usually reply within a day</small>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="contact-detail">
              Ontario, Canada
            </div>
          </div>
      </div>
    </div>
  </section>

  <!-- Copy toast -->
  <div class="copy-toast" id="copyToast">Copied to clipboard</div>
</BaseLayout>

<style>
  /* === HERO === */
  .hero {
    padding: 160px 24px 100px;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .hero-badge {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 500;
    color: #EB2D37;
    margin-bottom: 28px;
    letter-spacing: -0.3px;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -2.5px;
    color: var(--black);
    max-width: 800px;
    margin-bottom: 24px;
  }

  .hero h1 :global(.green) {
    color: var(--green);
    position: relative;
    display: inline-block;
  }

  .hero h1 :global(.green svg) {
    position: absolute;
    left: -4px;
    bottom: -4px;
    width: calc(100% + 8px);
    height: 12px;
    pointer-events: none;
  }

  .hero h1 :global(.green svg path) {
    stroke: var(--green);
    stroke-width: 3;
    fill: none;
    stroke-linecap: round;
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
  }

  .hero h1 :global(.green.entered svg path) {
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.5s;
  }

  .hero-sub {
    font-size: clamp(17px, 2vw, 20px);
    color: var(--grey-600);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
    font-family: var(--font);
  }

  .btn-primary {
    background: var(--green);
    color: white;
  }

  .btn-primary:hover {
    background: var(--green-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0, 133, 62, 0.3);
  }

  .btn-secondary {
    background: var(--grey-100);
    color: var(--grey-900);
  }

  .btn-secondary:hover {
    background: var(--grey-200);
  }

  /* === SECTION SHARED === */
  section {
    padding: 100px 24px;
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--green);
    margin-bottom: 16px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 44px);
    font-weight: 700;
    letter-spacing: -1.5px;
    line-height: 1.15;
    color: var(--black);
    margin-bottom: 16px;
  }

  .section-desc {
    font-size: 17px;
    color: var(--grey-600);
    max-width: 520px;
    line-height: 1.7;
  }

  /* === ABOUT === */
  .about {
    background: var(--grey-100);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    margin-top: 48px;
  }

  .about-text p {
    font-size: 17px;
    line-height: 1.8;
    color: var(--grey-800);
    margin-bottom: 20px;
  }

  .about-values {
    display: grid;
    gap: 20px;
  }

  .value-card {
    background: var(--white);
    padding: 24px 28px;
    border-left: 3px solid var(--green);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    transition: border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease;
  }

  .value-card:hover {
    border-color: var(--green-light);
  }

  .value-num {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 500;
    color: var(--green);
    letter-spacing: 0.5px;
    margin-bottom: 8px;
    display: block;
  }

  .value-card h4 {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--grey-900);
  }

  .value-card p {
    font-size: 14px;
    color: var(--grey-600);
    line-height: 1.6;
  }

  /* === GOPULSE PRODUCT === */
  .product { background: var(--white); }

  .product-showcase {
    margin-top: 56px;
    background: linear-gradient(135deg, #00853E 0%, #006B32 60%, #004d25 100%);
    border-radius: 24px;
    padding: 64px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
    overflow: hidden;
    position: relative;
  }

  .product-showcase::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .product-info { position: relative; z-index: 1; }

  .product-logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .product-logo-icon {
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,0.2);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-logo span {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: white;
    letter-spacing: -0.5px;
  }

  .product-tagline {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    color: white;
    line-height: 1.2;
    letter-spacing: -1px;
    margin-bottom: 20px;
  }

  .product-desc {
    font-size: 16px;
    color: rgba(255,255,255,0.8);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 440px;
  }

  .store-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .store-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.25);
    padding: 12px 22px;
    border-radius: 12px;
    color: white;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .store-badge:hover {
    background: rgba(255,255,255,0.25);
    transform: translateY(-1px);
  }

  .store-badge svg {
    width: 20px;
    height: 20px;
    fill: white;
  }

  .store-badge-text {
    display: flex;
    flex-direction: column;
  }

  .store-badge-small {
    font-size: 10px;
    font-weight: 400;
    opacity: 0.8;
    line-height: 1;
  }

  .store-badge-big {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.2;
  }

  /* === SCREENSHOT CAROUSEL === */
  .screenshot-carousel {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .carousel-phone {
    width: 280px;
    background: #1a1a1a;
    border-radius: 44px;
    padding: 14px;
    box-shadow:
      0 20px 60px rgba(0,0,0,0.3),
      0 0 0 1px rgba(255,255,255,0.1),
      inset 0 0 0 1px rgba(255,255,255,0.05);
    position: relative;
  }

  .carousel-phone::before {
    content: '';
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 28px;
    background: #1a1a1a;
    border-radius: 0 0 18px 18px;
    z-index: 2;
  }

  .carousel-phone::after {
    content: '';
    position: absolute;
    bottom: 22px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 4px;
    background: rgba(255,255,255,0.2);
    border-radius: 2px;
    z-index: 2;
  }

  .carousel-viewport {
    width: 100%;
    border-radius: 32px;
    overflow: hidden;
    position: relative;
  }

  .carousel-track {
    display: flex;
    width: 600%;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel-track img {
    width: calc(100% / 6);
    flex-shrink: 0;
    display: block;
  }

  .carousel-controls {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .carousel-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.15);
    color: white;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .carousel-btn:hover {
    background: rgba(255,255,255,0.3);
  }

  .carousel-dots {
    display: flex;
    gap: 8px;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel-dot.active {
    background: white;
    width: 24px;
    border-radius: 4px;
  }

  /* === FEATURES GRID === */
  .features {
    background: var(--grey-100);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .feature-card {
    background: var(--white);
    padding: 32px;
    border-radius: var(--radius);
    border: 1px solid var(--grey-200);
    opacity: 0;
    transform: translateY(20px);
  }

  .features-grid.visible .feature-card {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.25s ease;
  }

  .features-grid.visible .feature-card:hover {
    border-color: var(--green-100);
    box-shadow: var(--shadow-lg);
  }

  .features-grid.visible .feature-card:nth-child(1) { transition-delay: 0ms; }
  .features-grid.visible .feature-card:nth-child(2) { transition-delay: 70ms; }
  .features-grid.visible .feature-card:nth-child(3) { transition-delay: 140ms; }
  .features-grid.visible .feature-card:nth-child(4) { transition-delay: 210ms; }
  .features-grid.visible .feature-card:nth-child(5) { transition-delay: 280ms; }
  .features-grid.visible .feature-card:nth-child(6) { transition-delay: 350ms; }

  .feature-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 20px;
    color: var(--green);
  }

  .feature-icon svg {
    width: 100%;
    height: 100%;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .feature-card:hover .feature-icon svg {
    transform: scale(1.1) rotate(-3deg);
  }

  .feature-card h3 {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--grey-900);
  }

  .feature-card p {
    font-size: 14px;
    color: var(--grey-600);
    line-height: 1.65;
  }

  /* === CONTACT === */
  .contact {
    background: var(--white);
  }

  .contact-grid {
    margin-top: 48px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    background: var(--green-50);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-icon svg {
    width: 20px;
    height: 20px;
    stroke: var(--green);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .contact-detail {
    font-size: 14px;
    color: var(--grey-800);
  }

  .contact-detail a {
    color: var(--green);
    text-decoration: none;
    font-weight: 500;
  }

  .contact-detail a:hover { text-decoration: underline; }

  .contact-detail small {
    display: block;
    color: var(--grey-400);
    font-size: 12px;
    margin-top: 2px;
  }

  /* === EMAIL LINK CURSOR HINT === */
  .contact-detail a[href^="mailto"] {
    position: relative;
    cursor: pointer;
  }

  .contact-detail a[href^="mailto"]::after {
    content: 'click to copy';
    position: absolute;
    right: -90px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 11px;
    color: var(--grey-400);
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
    pointer-events: none;
  }

  .contact-detail a[href^="mailto"]:hover::after {
    opacity: 1;
  }

  /* === ANIMATIONS === */
  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Hero entrance */
  .hero-badge,
  .hero h1,
  .hero-sub,
  .hero-cta {
    opacity: 0;
    transform: translateY(20px);
  }

  .hero-badge.entered,
  .hero h1.entered,
  .hero-sub.entered,
  .hero-cta.entered {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Button press */
  .btn:active {
    transform: translateY(1px) !important;
    box-shadow: none !important;
    transition: transform 0.06s, box-shadow 0.06s !important;
  }

  .store-badge:active {
    transform: translateY(1px) scale(0.98) !important;
    transition: transform 0.06s !important;
  }

  /* Nav scroll shrink */
  :global(nav.scrolled .nav-inner) {
    height: 52px;
  }

  :global(nav.scrolled) {
    background: rgba(26, 36, 32, 0.95);
    box-shadow: 0 1px 8px rgba(0,0,0,0.12);
  }

  /* Copy toast */
  .copy-toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--grey-900);
    color: var(--white);
    padding: 10px 20px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    font-family: var(--font);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 200;
  }

  .copy-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* === REDUCED MOTION === */
  @media (prefers-reduced-motion: reduce) {
    .hero-badge,
    .hero h1,
    .hero-sub,
    .hero-cta {
      opacity: 1;
      transform: none;
    }

    .hero-badge.entered,
    .hero h1.entered,
    .hero-sub.entered,
    .hero-cta.entered {
      transition: none;
    }

    .hero h1 :global(.green svg path) {
      stroke-dashoffset: 0;
    }
    .hero h1 :global(.green.entered svg path) {
      transition: none;
    }

    .fade-up {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .feature-card {
      opacity: 1;
      transform: none;
    }

    .features-grid.visible .feature-card {
      transition: none;
    }

    .value-card,
    .feature-card,
    .btn,
    .store-badge,
    .carousel-dot {
      transition: none !important;
    }
  }

  /* === RESPONSIVE === */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .product-showcase {
      grid-template-columns: 1fr;
      padding: 40px 32px;
      text-align: center;
    }

    .product-desc { max-width: 100%; }
    .store-badges { justify-content: center; }
    .screenshot-carousel { margin-top: 20px; }

    .carousel-phone {
      width: 240px;
      border-radius: 38px;
      padding: 12px;
    }

    .carousel-phone::before {
      width: 84px;
      height: 24px;
      top: 12px;
    }

    .features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero { padding: 130px 20px 60px; }

    .hero h1 :global(.green svg) {
      bottom: -2px;
      height: 8px;
    }

    section { padding: 64px 20px; }

    .contact-detail a[href^="mailto"]::after {
      display: none;
    }

    .hero h1 { letter-spacing: -1px; }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .product-showcase {
      padding: 32px 24px;
    }
  }
</style>

<script is:inline>
  // Scroll-triggered fade-in animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  // Feature card stagger (separate observer)
  const featuresGrid = document.querySelector('.features-grid');
  if (featuresGrid) {
    const featureObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });
    featureObserver.observe(featuresGrid);
  }

  // Hero staggered entrance
  (function() {
    const heroEls = document.querySelectorAll('.hero-badge, .hero h1, .hero-sub, .hero-cta');
    const delays = [100, 200, 340, 480];
    heroEls.forEach((el, i) => {
      setTimeout(() => el.classList.add('entered'), delays[i]);
    });
    const greenSpan = document.querySelector('.hero h1 .green');
    if (greenSpan) setTimeout(() => greenSpan.classList.add('entered'), 600);
  })();

  // Nav shrink on scroll
  (function() {
    const nav = document.getElementById('nav');
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          nav.classList.toggle('scrolled', window.scrollY > 40);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  })();

  // Close mobile nav on link click
  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => {
      document.getElementById('nav').classList.remove('open');
    });
  });

  // Copy email to clipboard
  (function() {
    const emailLink = document.querySelector('.contact-detail a[href^="mailto"]');
    if (emailLink) {
      emailLink.addEventListener('click', (e) => {
        e.preventDefault();
        const email = emailLink.textContent.trim();
        navigator.clipboard.writeText(email).then(() => {
          const toast = document.getElementById('copyToast');
          toast.classList.add('show');
          setTimeout(() => toast.classList.remove('show'), 2000);
        });
      });
    }
  })();

  // Screenshot carousel
  (function() {
    const track = document.getElementById('carouselTrack');
    const dots = document.querySelectorAll('.carousel-dot');
    const prevBtn = document.getElementById('carouselPrev');
    const nextBtn = document.getElementById('carouselNext');
    const total = dots.length;
    let current = 0;
    let autoTimer;

    function goTo(index) {
      current = (index + total) % total;
      track.style.transform = 'translateX(-' + (current * 100 / total) + '%)';
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    prevBtn.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
    nextBtn.addEventListener('click', () => { goTo(current + 1); resetAuto(); });
    dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); resetAuto(); }));

    // Touch/swipe support
    let startX = 0;
    track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', e => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) { goTo(current + (diff > 0 ? 1 : -1)); resetAuto(); }
    });

    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => goTo(current + 1), 4000);
    }
    resetAuto();
  })();

  // Console Easter egg
  console.log(
    '%cNorthStack Labs',
    'color: #00853E; font-size: 20px; font-weight: bold; font-family: system-ui;'
  );
  console.log(
    '%cBuilt with care in Ontario, Canada.\nCurious how things work? We like that about you.',
    'color: #555; font-size: 13px; font-family: system-ui;'
  );
</script>
