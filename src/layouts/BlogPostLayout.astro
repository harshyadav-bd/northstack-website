---
import BaseLayout from './BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date | undefined;
  author?: string | undefined;
}

const { title, description, pubDate, updatedDate, author = 'Harsh Yadav' } = Astro.props;

const jsonLdData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: author,
  },
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  publisher: {
    '@type': 'Organization',
    name: 'NorthStack Labs Inc.',
    url: 'https://northstacklabs.ca',
  },
};

const formattedDate = pubDate.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${title} — NorthStack Labs Blog`}
  description={description}
  navVariant="subpage"
  footerVariant="subpage"
  ogType="article"
  publishDate={pubDate}
>
  <Fragment slot="head">
    <JsonLd data={jsonLdData} />
  </Fragment>

  <main class="blog-post">
    <div class="blog-header">
      <a href="/blog" class="back-link">&larr; Back to Blog</a>
      <h1 style="margin-top: 16px;">{title}</h1>
      <p class="blog-meta">
        <span class="blog-author">{author}</span>
        <span class="blog-date">{formattedDate}</span>
        {updatedDate && <span class="blog-updated">(Updated {updatedDate.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })})</span>}
      </p>
    </div>
    <article class="prose">
      <slot />
    </article>
  </main>
</BaseLayout>

<style>
  .blog-post {
    max-width: 780px;
    margin: 0 auto;
    padding: 120px 24px 80px;
  }

  .blog-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--grey-200);
  }

  .blog-header h1 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -1px;
    color: var(--black);
    margin-bottom: 12px;
  }

  .blog-meta {
    font-size: 14px;
    color: var(--grey-400);
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .blog-author {
    color: var(--green);
    font-weight: 500;
  }

  .blog-date::before {
    content: '·';
    margin-right: 12px;
  }

  /* Prose styles for rendered Markdown */
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--grey-900);
    margin-top: 40px;
    margin-bottom: 16px;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--grey-900);
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .prose :global(p) {
    font-size: 16px;
    color: var(--grey-600);
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .prose :global(ul),
  .prose :global(ol) {
    font-size: 16px;
    color: var(--grey-600);
    line-height: 1.8;
    margin-bottom: 20px;
    padding-left: 24px;
  }

  .prose :global(li) {
    margin-bottom: 8px;
  }

  .prose :global(a) {
    color: var(--green);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: var(--green-dark);
  }

  .prose :global(code) {
    font-family: var(--mono);
    font-size: 14px;
    background: var(--grey-100);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--grey-800);
  }

  .prose :global(pre) {
    background: var(--grey-900);
    color: var(--grey-200);
    padding: 24px;
    border-radius: var(--radius-sm);
    overflow-x: auto;
    margin-bottom: 24px;
    font-size: 14px;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    color: inherit;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--green);
    padding-left: 20px;
    margin-bottom: 20px;
    color: var(--grey-600);
    font-style: italic;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    margin: 24px auto;
    display: block;
  }

  .prose :global(.app-icon-block) {
    text-align: center;
    margin: 32px 0;
  }

  .prose :global(.app-icon-block img) {
    width: 100px;
    border-radius: 22px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    margin: 0 auto;
  }

  .prose :global(.screenshot-pair) {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin: 32px 0;
  }

  .prose :global(.screenshot-pair img) {
    max-width: 260px;
    width: 100%;
    margin: 0;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--grey-200);
    margin: 40px 0;
  }

  @media (max-width: 640px) {
    .blog-post { padding: 110px 20px 60px; }
    .blog-header h1 { font-size: 28px; }
    .prose :global(.screenshot-pair) {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
