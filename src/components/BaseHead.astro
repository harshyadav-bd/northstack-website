---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article' | undefined;
  ogImage?: string | undefined;
  publishDate?: Date | undefined;
}

const {
  title,
  description,
  ogType = 'website',
  ogImage,
  publishDate,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const siteName = 'NorthStack Labs';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="theme-color" content="#00853E" />
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%231a2420'/><text x='50' y='72' font-size='60' fill='%2300853E' font-family='Space Grotesk,sans-serif' font-weight='700' text-anchor='middle'>N</text></svg>" />
<link rel="canonical" href={canonicalUrl} />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:site_name" content={siteName} />
{ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />}

{publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="NorthStack Labs Blog" href="/rss.xml" />
